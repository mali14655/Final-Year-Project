# MongoDB (use MongoDB Atlas connection string in production)
# If Atlas adds `appName=` with no value, the server auto-strips empty URI params.
MONGODB_URI=mongodb://localhost:27017/cursor-for-pms

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL for CORS and auth cookies (no trailing slash)
# Comma-separate multiple URLs for Vercel preview deployments
FRONTEND_ORIGIN=http://localhost:3000

# Super admin (only one account — created on server start if it does not exist)
SUPER_ADMIN_EMAIL=admin@parseai.local
SUPER_ADMIN_PASSWORD=change-me-super-admin-password
SUPER_ADMIN_NAME=Super Admin
